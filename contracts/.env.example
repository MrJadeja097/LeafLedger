# ------------------------------------------------------------------------------
# LeafLedger Contracts Deployment Configuration
# ------------------------------------------------------------------------------

# 1. Provide your Deployer Wallet Private Key (Without 0x prefix)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# 2. Provide the Initia Network RPC URL
RPC_URL=https://rpc-testnet.initia.xyz

# 3. (Optional) Set the block explorer verify API key
# ETHERSCAN_API_KEY=your_explorer_api_key

# 4. (Optional) Reward amount per tree planted (Default: 100 ECO tokens - 18 decimals)
# 100 * 10^18 = 100000000000000000000
# REWARD_AMOUNT=100000000000000000000
